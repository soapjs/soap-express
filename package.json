{
  "name": "@soapjs/soap-express",
  "version": "1.0.1",
  "description": "HTTP-focused Express.js integration for @soapjs/soap framework with dependency injection support",
  "homepage": "https://docs.soapjs.com",
  "repository": "https://github.com/soapjs/soap-express",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "require": "./build/index.js",
      "types": "./build/index.d.ts"
    },
    "./cqrs": {
      "require": "./build/cqrs.js",
      "types": "./build/cqrs.d.ts"
    },
    "./auth": {
      "require": "./build/auth/index.js",
      "types": "./build/auth/index.d.ts"
    }
  },
  "license": "MIT",
  "author": "Radoslaw Kamysz",
  "scripts": {
    "test:unit": "jest --config=jest.config.unit.json",
    "test:memory": "node --expose-gc scripts/memory-budget.js",
    "test:integration": "ts-node scripts/run-integration-tests.ts",
    "clean": "rm -rf ./build",
    "build": "npm run clean && tsc -b tsconfig.build.json",
    "prepublish": "npm run build",
    "test:imports": "node scripts/auth-import-smoke.js"
  },
  "devDependencies": {
    "@soapjs/soap": "0.14.0",
    "@soapjs/soap-auth": "1.0.1",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.2",
    "@types/supertest": "^7.2.0",
    "express": "^4.0.0",
    "jest": "^30.4.2",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@soapjs/soap": ">=0.14.0",
    "@soapjs/soap-auth": ">=1.0.1",
    "express": ">=4.0.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0"
  },
  "engines": {
    "node": ">=24.17.0"
  },
  "peerDependenciesMeta": {
    "@soapjs/soap-auth": {
      "optional": true
    }
  },
  "overrides": {
    "js-yaml": "^5.0.0"
  },
  "files": [
    "build",
    "!build/**/*.tsbuildinfo",
    "README.md",
    "LICENSE"
  ]
}
